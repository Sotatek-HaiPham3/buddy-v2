{
  "name": "@buddy/serve",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --sourcemap",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@buddy/query": "workspace:*",
    "@buddy/server": "workspace:*",
    "@buddy/shared": "workspace:*",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
