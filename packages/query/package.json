  },
  "dependencies": {
    "@buddy/shared": "workspace:*",
    "chokidar": "^3.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pdf-lib": "^1.17.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
